<?xml version="1.0" encoding="utf-8"?>
<!--
  overlay_roast.xml
  This is the full-screen view that BLASTS over Instagram when locked.
  Prettycoolstrangers aesthetic: yellow/red/blue blocks, zine typography,
  dot-matrix countdown, hand-drawn doodle face.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white">

    <!-- GRAIN TEXTURE OVERLAY (semi-transparent pattern) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/grain_texture"
        android:alpha="0.03" />

    <!-- TOP TICKER BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/brand_red"
            android:scrollbars="none"
            android:overScrollMode="never">
            <TextView
                android:id="@+id/tv_ticker"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="LOCKED OUT ★ SKILL ISSUE ★ TOUCH GRASS ★ GO DRINK WATER ★ LOCKED OUT ★ READ A BOOK ★ LOCKED OUT ★ SKILL ISSUE ★"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"/>
        </HorizontalScrollView>

        <!-- MAIN CONTENT ROW: sidebar + content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- LEFT SIDEBAR (blue, like the website) -->
            <LinearLayout
                android:layout_width="160dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/brand_blue"
                android:paddingTop="12dp">

                <!-- Logo block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/black"
                    android:layout_margin="10dp"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOOM\nSCROLL\nDESTROYER"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-condensed"
                        android:lineSpacingMultiplier="0.9"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="dot app!"
                        android:textColor="@color/brand_yellow"
                        android:textSize="13sp"
                        android:fontFamily="cursive"/>
                </LinearLayout>

                <!-- Nav items (all locked/red) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOCKED"
                    android:background="@color/brand_red"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:layout_marginTop="0dp"/>
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="@color/black"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOCKED"
                    android:background="@color/brand_red"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"/>
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="@color/black"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOCKED"
                    android:background="@color/brand_red"
                    android:textColor="@color/white"
                    android:alpha="0.3"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"/>

                <!-- Specs text at bottom -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="bottom"
                    android:layout_marginBottom="16dp"
                    android:paddingHorizontal="10dp"
                    android:text="INSTAGRAM: BLOCKED\nACC SVC: ON\nOVERLAY: ARMED\nSTATUS: NO."
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- RIGHT CONTENT AREA -->
            <ScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- HEADLINE -->
                    <TextView
                        android:id="@+id/tv_headline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOU\nLITERALLY\nCANNOT."
                        android:textColor="@color/black"
                        android:textSize="72sp"
                        android:fontFamily="sans-serif-condensed"
                        android:lineSpacingMultiplier="0.85"
                        android:layout_marginBottom="16dp"/>

                    <!-- ROAST MESSAGE BOX (yellow, rotated slightly) -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:rotation="-1.2">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/box_yellow_bordered"
                            android:padding="20dp">

                            <!-- Opening quote mark -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text='"'
                                android:textSize="48sp"
                                android:fontFamily="cursive"
                                android:textColor="@color/black"
                                android:alpha="0.4"
                                android:lineSpacingMultiplier="0.5"
                                android:layout_marginTop="-8dp"/>

                            <TextView
                                android:id="@+id/tv_roast_message"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="babe you just watched someone's vacation reel for the 4th time."
                                android:textColor="@color/black"
                                android:textSize="20sp"
                                android:fontFamily="cursive"
                                android:lineSpacingMultiplier="1.3"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- DOT MATRIX COUNTDOWN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/black"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tv_countdown_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INSTAGRAM RETURNS IN"
                            android:textColor="@color/brand_red"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-condensed"
                            android:letterSpacing="0.3"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tv_countdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="29:59"
                            android:textColor="@color/brand_red"
                            android:textSize="64sp"
                            android:fontFamily="monospace"
                            android:lineSpacingMultiplier="0.9"/>
                    </LinearLayout>

                    <!-- DOODLE FACE + STICKERS ROW -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <!-- Giant emoji face -->
                        <TextView
                            android:id="@+id/tv_doodle_face"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😤"
                            android:textSize="72sp"
                            android:layout_marginEnd="16dp"/>

                        <!-- Stickers column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="skill issue"
                                android:background="@drawable/sticker_red"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:fontFamily="cursive"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="6dp"
                                android:rotation="1.5"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="touch grass"
                                android:background="@drawable/sticker_blue"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:fontFamily="cursive"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="6dp"
                                android:rotation="-2"
                                android:layout_marginTop="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="go drink water"
                                android:background="@drawable/sticker_yellow"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:fontFamily="cursive"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="6dp"
                                android:rotation="2.5"
                                android:layout_marginTop="8dp"/>

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

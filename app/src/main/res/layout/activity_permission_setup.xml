<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/off_white">

    <!-- TICKER -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/brand_yellow"
        android:scrollbars="none">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="SETUP REQUIRED ★ DO THIS ONCE ★ THEN NEVER AGAIN ★ SETUP REQUIRED ★ DO THIS ONCE ★"
            android:textColor="@color/black"
            android:textSize="17sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"/>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- HEADLINE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FIRST TIME\nSETUP."
                android:textColor="@color/black"
                android:textSize="60sp"
                android:fontFamily="sans-serif-condensed"
                android:lineSpacingMultiplier="0.88"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↳ do this once, never think about it again"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="cursive"
                android:rotation="-1"
                android:layout_marginBottom="24dp"/>

            <!-- STEP 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="01. ACCESSIBILITY SERVICE"
                        android:textColor="@color/brand_yellow"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tv_step1_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗ NOT YET"
                        android:textColor="@color/brand_red"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lets the app see when Instagram opens. Tap below → find 'Doomscroll Destroyer' → toggle ON."
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btn_step1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="OPEN ACCESSIBILITY SETTINGS →"
                    android:backgroundTint="@color/brand_blue"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <!-- STEP 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="02. DISPLAY OVER OTHER APPS"
                        android:textColor="@color/brand_yellow"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tv_step2_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗ NOT YET"
                        android:textColor="@color/brand_red"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Draws the roast screen ON TOP of Instagram when you're locked. Without this, the whole app is useless."
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btn_step2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="ALLOW OVERLAY PERMISSION →"
                    android:backgroundTint="@color/brand_red"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <!-- STEP 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="03. USAGE STATS ACCESS"
                        android:textColor="@color/brand_yellow"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tv_step3_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗ NOT YET"
                        android:textColor="@color/brand_red"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Backup detection method. Recommended but optional. Helps track time even if accessibility service is briefly interrupted."
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btn_step3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="GRANT USAGE STATS →"
                    android:backgroundTint="#444444"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <!-- NOTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/brand_yellow"
                android:padding="16dp"
                android:rotation="-0.5">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="why so many permissions?"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="cursive"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Because Instagram is a billion-dollar app with a billion-dollar engineering team whose only job is to keep you scrolling. Beating them requires playing hardball. These permissions are the hardball."
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
